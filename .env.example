# Base de datos PostgreSQL
POSTGRES_DATABASE=gsys
POSTGRES_PASSWORD=change_me

# Usada por Prisma (apunta al contenedor postgres en Docker, o a Supabase en producción)
DATABASE_URL=postgresql://postgres:change_me@postgres:5432/gsys

# JWT
JWT_SECRET=change_me_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Redis (por defecto apunta al contenedor redis en Docker)
REDIS_HOST=redis
REDIS_PORT=6379

# Puerto de la aplicación
PORT=3000
