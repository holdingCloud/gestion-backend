// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum typePosition {
  SUPER_ADMIN
  ADMINISTRADOR
}

enum TiposDireccion {
  PRINCIPAL
  FACTURACION
  DESPACHO
  COMERCIAL
  TRABAJO
  SUCURSAL
  BODEGA
  OTRO
}

enum ContactStatus {
  LLAMAR
  CONTACTADO
  VENCIDO
}

enum PurchaseStatus {
  PENDIENTE
  FINALIZADO
  ANULADO
}

enum FrequencyStatus {
  NUEVO
  EN_PLAZO
  POR_VENCER
  VENCIDO
}

model Users {
  id       Int      @id @default(autoincrement())
  fullName String   @db.VarChar(200)
  email    String   @unique @db.VarChar(30)
  password String   @db.VarChar(150)
  imagen   String   @db.VarChar(150)
  rol      Roles     @relation(fields: [rolesId], references: [id])
  rolesId  Int
  isActive Boolean @default(true)
  isLoged  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Roles {
  id        Int         @id @default(autoincrement())
  type      String      @unique @db.VarChar(50)
  user      Users[]
  modulos   RolModulo[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum Modulo {
  DASHBOARD
  USUARIOS
  CLIENTES
  RRHH
  INVENTARIO
  COMPRAS
  PROVEEDORES
  CUENTAS
  HOJA_DE_VENTA
  REPORTES
  EMPRESAS
}

model RolModulo {
  id        Int      @id @default(autoincrement())
  rolId     Int
  modulo    Modulo
  rol       Roles    @relation(fields: [rolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([rolId, modulo])
  @@index([rolId])
}

model Products {
  id                       Int                      @id @default(autoincrement())
  name                     String                   @db.VarChar(25)
  description              String                   @db.VarChar(50)
  quantity                 Int
  available                Boolean                  @default(true)
  img                      String                   @db.VarChar(50)
  code                     String                   @db.VarChar(50)
  detailsSalesSheets       detailsSalesSheet[]
  buysByClient             buyByClient[]
  clientProductFrequencies ClientProductFrequency[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([available])
}

model Region {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  communes  Commune[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Commune {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  region      Region        @relation(fields: [regionId], references: [id])
  regionId    Int
  direcciones Direcciones[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Direcciones {
  id           Int            @id @default(autoincrement())
  tipo         TiposDireccion
  calle        String         @db.VarChar(200)
  numero       String?        @db.VarChar(20)
  departamento String?        @db.VarChar(50)
  referencia   String?        @db.VarChar(200)
  commune      Commune?       @relation(fields: [communeId], references: [id])
  communeId    Int?
  latitud      Decimal?       @db.Decimal(10, 8)
  longitud     Decimal?       @db.Decimal(11, 8)
  client       Clients?
  employee     Employees?
  company      Company?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([communeId])
  @@index([tipo])
}

model Company {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(150)
  description String?      @db.VarChar(500)
  clients     Clients[]
  direccionId Int?         @unique
  direccion   Direcciones? @relation(fields: [direccionId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Clients {
  id                       Int                      @id @default(autoincrement())
  fullname                 String                   @db.VarChar(150)
  phone                    String                   @db.VarChar(15)
  phone2                   String?                  @db.VarChar(15)
  email                    String                   @db.VarChar(100)
  company                  Company?                 @relation(fields: [companyId], references: [id])
  companyId                Int?
  direccionId              Int?                     @unique
  direccion                Direcciones?             @relation(fields: [direccionId], references: [id])
  detailsSalesSheets       detailsSalesSheet[]
  buysByClient             buyByClient[]
  clientProductFrequencies ClientProductFrequency[]
  available                Boolean                  @default(true)
  contactStatus            ContactStatus            @default(LLAMAR)
  frequency                Int?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([available])
  @@index([companyId])
}

model buyByClient {
  id             Int            @id @default(autoincrement())
  client         Clients        @relation(fields: [clientsId], references: [id])
  clientsId      Int
  product        Products       @relation(fields: [productsId], references: [id])
  productsId     Int
  quantity       Int
  unitPrice      Float
  purchaseDate   DateTime?
  purchaseStatus PurchaseStatus @default(PENDIENTE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clientsId, productsId])
  @@index([clientsId, createdAt])
}

model ClientProductFrequency {
  id                      Int             @id @default(autoincrement())
  client                  Clients         @relation(fields: [clientsId], references: [id])
  clientsId               Int
  product                 Products        @relation(fields: [productsId], references: [id])
  productsId              Int
  purchaseCount           Int             @default(0)
  avgDaysBetweenPurchases Int?
  lastPurchaseDate        DateTime?
  actualPurchaseDate      DateTime?
  nextEstimatedDate       DateTime?
  status                  FrequencyStatus @default(NUEVO)
  updatedAt               DateTime        @updatedAt

  @@unique([clientsId, productsId])
  @@index([nextEstimatedDate])
  @@index([status])
}

model Employees {
  id          Int          @id @default(autoincrement())
  rut         String       @db.VarChar(20)
  fullname    String       @db.VarChar(150)
  email       String       @db.VarChar(100)
  salary      Int
  hireDate    String       @db.VarChar(20)
  available   Boolean      @default(true)
  type        typePosition @default(ADMINISTRADOR)
  salesSheets salesSheets[]
  direccionId Int?         @unique
  direccion   Direcciones? @relation(fields: [direccionId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([available])
}

model Bills {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(50)
  details     BillDetails[]
  salesSheets salesSheets[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BillDetails {
  id        Int      @id @default(autoincrement())
  amount    Int
  date      DateTime
  bill      Bills    @relation(fields: [billsId], references: [id])
  billsId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model salesSheets {
  id                Int                 @id @default(autoincrement())
  employee          Employees           @relation(fields: [employeeId], references: [id])
  employeeId        Int
  date              DateTime
  description       String              @db.Text
  bill              Bills               @relation(fields: [billId], references: [id])
  billId            Int
  detailsSalesSheet detailsSalesSheet[]
}

model detailsSalesSheet {
  id           Int         @id @default(autoincrement())
  client       Clients     @relation(fields: [clientsId], references: [id])
  clientsId    Int
  product      Products    @relation(fields: [productsId], references: [id])
  productsId   Int
  quantity     Int
  discount     Float
  salesSheet   salesSheets @relation(fields: [salesSheetId], references: [id])
  salesSheetId Int
}