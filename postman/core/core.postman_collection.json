{
  "info": {
    "name": "Gestion Backend - Core Modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Requests for Auth, Users, Clients, Employees and Products endpoints"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "clientId",
      "value": "1"
    },
    {
      "key": "employeeId",
      "value": "1"
    },
    {
      "key": "productId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{refreshToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"fullName\": \"Jane Doe\",\n  \"password\": \"123456\",\n  \"imagen\": \"avatar.png\",\n  \"rol\": 1,\n  \"isActive\": true,\n  \"isLoged\": false\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get Users (Paginated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?page=1&limit=10"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe Updated\",\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Carlos Perez\",\n  \"city\": \"Bogota\",\n  \"address\": \"Calle 123 #45-67\",\n  \"zone\": \"North\",\n  \"phone\": \"3001234567\",\n  \"email\": \"carlos@example.com\"\n}"
            },
            "url": "{{baseUrl}}/client"
          }
        },
        {
          "name": "Get Clients (Paginated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/client?page=1&limit=10"
          }
        },
        {
          "name": "Get Client By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/client/{{clientId}}"
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"3007654321\",\n  \"city\": \"Medellin\"\n}"
            },
            "url": "{{baseUrl}}/client/{{clientId}}"
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/client/{{clientId}}"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rut\": \"1020304050\",\n  \"fullname\": \"Ana Torres\",\n  \"email\": \"ana@example.com\",\n  \"salary\": 2500000,\n  \"hireDate\": \"2026-02-26\",\n  \"city\": \"Bogota\",\n  \"address\": \"Av 10 #20-30\",\n  \"type\": \"COMUN\"\n}"
            },
            "url": "{{baseUrl}}/employee"
          }
        },
        {
          "name": "Get Employees (Paginated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employee?page=1&limit=10"
          }
        },
        {
          "name": "Get Employee By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employee/{{employeeId}}"
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 2800000,\n  \"city\": \"Cali\"\n}"
            },
            "url": "{{baseUrl}}/employee/{{employeeId}}"
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/employee/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"description\": \"14 inch, 16GB RAM\",\n  \"quantity\": 5,\n  \"img\": \"laptop.jpg\",\n  \"code\": \"LP-001\",\n  \"available\": true\n}"
            },
            "url": "{{baseUrl}}/product"
          }
        },
        {
          "name": "Get Products (Paginated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/product?page=1&limit=10"
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/product/{{productId}}"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 8,\n  \"available\": true\n}"
            },
            "url": "{{baseUrl}}/product/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/product/{{productId}}"
          }
        }
      ]
    }
  ]
}
